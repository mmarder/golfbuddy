---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/paths';
---

<BaseLayout
  title="Practice · GolfBuddy"
  description="Daily drills and how-to guides in one place."
>
  <header class="mb-6">
    <h1 class="text-2xl font-bold">🎯 Practice</h1>
    <p class="mt-1 text-base-content/70">Everything you need to make every session count.</p>
  </header>

  <div class="flex flex-col gap-3">
    <a
      href={withBase('practice/drills/')}
      class="card bg-primary text-primary-content shadow-sm transition active:scale-[0.99]"
    >
      <div class="card-body flex-row items-center gap-4 p-5">
        <span class="text-3xl" aria-hidden="true">🔁</span>
        <div>
          <h2 class="card-title">Daily Drills</h2>
          <p class="text-sm opacity-90">Core-swing routine — do anywhere with your clubs.</p>
        </div>
      </div>
    </a>

    <a
      href={withBase('practice/how/')}
      class="card bg-base-100 shadow-sm transition active:scale-[0.99]"
    >
      <div class="card-body flex-row items-center gap-4 p-5">
        <span class="text-3xl" aria-hidden="true">🧠</span>
        <div>
          <h2 class="card-title">How to Practice</h2>
          <p class="text-sm text-base-content/70">Structure sessions so every rep counts.</p>
        </div>
      </div>
    </a>
  </div>
</BaseLayout>
