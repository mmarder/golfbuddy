---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import BenchmarkBlock from '../components/BenchmarkBlock.astro';

export const getStaticPaths = (async () => {
  const areas = await getCollection('areas');
  return areas.map((entry) => ({ params: { area: entry.id }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);

/** Maps each area page to the benchmark section(s) it should show, if any. */
const benchmarkSection: Record<string, 'putting' | 'shortGame' | 'long' | null> = {
  putting: 'putting',
  'short-game': 'shortGame',
  'long-game': 'long',
  fundamentals: null,
};

const section = benchmarkSection[entry.id] ?? null;
---

<BaseLayout title={`${entry.data.title} · GolfBuddy`} description={entry.data.summary}>
  <header class="mb-4">
    <h1 class="flex items-center gap-2 text-2xl font-bold">
      <span aria-hidden="true">{entry.data.icon}</span>
      <span>{entry.data.title}</span>
    </h1>
    <p class="text-base-content/70">{entry.data.summary}</p>
  </header>

  <article class="prose prose-sm max-w-none">
    <Content />
  </article>

  {section && <BenchmarkBlock section={section} />}
</BaseLayout>
