---
import '../styles/global.css';
import { withBase } from '../lib/paths';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal golf practice notes and daily drills.' } = Astro.props;

const nav = [
  { href: withBase(''), label: 'Home', icon: '🏠', prefix: null },
  { href: withBase('practice/'), label: 'Practice', icon: '🎯', prefix: withBase('practice/') },
  { href: withBase('long-game/'), label: 'Long', icon: '🏌️', prefix: null },
  { href: withBase('short-game/'), label: 'Short', icon: '⛳', prefix: null },
  { href: withBase('putting/'), label: 'Putt', icon: '🥅', prefix: null },
  { href: withBase('learn/'), label: 'Learn', icon: '📖', prefix: withBase('learn/') },
];

// Normalise the current path (with or without trailing slash) for active matching.
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';

/**
 * Returns true when the nav item should be highlighted.
 * - Exact match for all items.
 * - Prefix match when `prefix` is set: highlights the item for any sub-page
 *   (e.g. Practice stays highlighted on /practice/drills/, /practice/how/, etc.).
 */
const isActive = (item: (typeof nav)[number]): boolean => {
  const clean = item.href.replace(/\/+$/, '') || '/';
  if (clean === current) return true;
  if (item.prefix) {
    const cleanPrefix = item.prefix.replace(/\/+$/, '');
    if (current.startsWith(cleanPrefix + '/')) return true;
  }
  return false;
};
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-base-200">
    <!-- pb clears the fixed dock; safe-area handled by the dock component itself -->
    <main class="mx-auto max-w-screen-sm px-4 pt-6 pb-28">
      <slot />
    </main>

    <nav class="dock bg-base-100">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class={isActive(item) ? 'dock-active' : ''}
            aria-current={isActive(item) ? 'page' : undefined}
          >
            <span class="text-xl" aria-hidden="true">
              {item.icon}
            </span>
            <span class="dock-label">{item.label}</span>
          </a>
        ))
      }
    </nav>
  </body>
</html>
