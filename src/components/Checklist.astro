---
interface DrillStep {
  heading: string;
  cues: string[];
}

interface DrillItem {
  id: string;
  title: string;
  detail?: string;
  steps?: DrillStep[];
}

interface Props {
  items: DrillItem[];
}

const { items } = Astro.props;
---

{
  items.length === 0 ? (
    <div class="alert" role="status">
      <span>No drills yet — add some in <code>src/content/drills.json</code>.</span>
    </div>
  ) : (
    <div data-checklist>
      <div class="mb-4 flex items-center gap-3">
        <progress
          class="progress progress-primary flex-1"
          data-progress-bar
          value="0"
          max="100"
          aria-label="Drills completed"
        />
        <span class="text-sm font-medium tabular-nums text-base-content/70" data-progress-text>
          0 / {items.length}
        </span>
      </div>

      <ul class="flex flex-col gap-2">
        {items.map((item) => (
          <li class="rounded-box bg-base-100 shadow-sm overflow-hidden">
            <label class="flex cursor-pointer items-start gap-3 p-4">
              <input
                type="checkbox"
                class="checkbox checkbox-primary mt-0.5 shrink-0"
                data-drill-id={item.id}
              />
              <span class="flex flex-col">
                <span class="font-semibold">{item.title}</span>
                {item.detail && (
                  <span class="text-sm text-base-content/70">{item.detail}</span>
                )}
              </span>
            </label>
            {item.steps && item.steps.length > 0 && (
              <details class="border-t border-base-200">
                <summary class="steps-summary flex cursor-pointer items-center gap-2 px-4 py-3 text-sm font-medium text-primary select-none">
                  <svg xmlns="http://www.w3.org/2000/svg" class="steps-chevron h-4 w-4 shrink-0 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                  Show steps
                </summary>
                <div class="px-4 pb-4 pt-2 flex flex-col gap-4">
                  {item.steps.map((step) => (
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-wide text-base-content/60 mb-1">{step.heading}</p>
                      <ul class="list-disc pl-4 flex flex-col gap-0.5">
                        {step.cues.map((cue) => (
                          <li class="text-sm text-base-content/70">{cue}</li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </details>
            )}
          </li>
        ))}
      </ul>

      <button type="button" class="btn btn-outline mt-5" data-reset>
        Reset checklist
      </button>
    </div>
  )
}

<script>
  import {
    deserialize,
    serialize,
    toggle,
    reset,
    progress,
    type ChecklistState,
  } from '../lib/checklist-state';

  const STORAGE_KEY = 'golfbuddy.drills';

  function load(): ChecklistState {
    try {
      return deserialize(localStorage.getItem(STORAGE_KEY));
    } catch {
      // localStorage can throw (private mode / disabled). Fall back to empty.
      return { checked: [] };
    }
  }

  function save(state: ChecklistState): void {
    try {
      localStorage.setItem(STORAGE_KEY, serialize(state));
    } catch {
      // Persistence unavailable — the UI still works for this session.
    }
  }

  function init(root: HTMLElement): void {
    const boxes = Array.from(
      root.querySelectorAll<HTMLInputElement>('input[data-drill-id]'),
    );
    const bar = root.querySelector<HTMLProgressElement>('[data-progress-bar]');
    const text = root.querySelector<HTMLElement>('[data-progress-text]');
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-reset]');
    const allIds = boxes.map((b) => b.dataset.drillId!).filter(Boolean);

    let state = load();

    function paint(): void {
      for (const box of boxes) {
        box.checked = state.checked.includes(box.dataset.drillId!);
      }
      const { done, total, percent } = progress(state, allIds);
      if (bar) bar.value = percent;
      if (text) text.textContent = `${done} / ${total}`;
    }

    for (const box of boxes) {
      box.addEventListener('change', () => {
        state = toggle(state, box.dataset.drillId!);
        save(state);
        paint();
      });
    }

    resetBtn?.addEventListener('click', () => {
      state = reset();
      save(state);
      paint();
    });

    paint();
  }

  const root = document.querySelector<HTMLElement>('[data-checklist]');
  if (root) init(root);
</script>

<style>
  /* Rotate chevron when the steps disclosure is open */
  details[open] .steps-chevron {
    transform: rotate(180deg);
  }
</style>
